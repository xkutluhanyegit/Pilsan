@{
    ViewData["Title"] = "Kullanıcı Giriş";
    Layout = "_LoginLayout";
}

@model Web.Models.LoginViewModel

<div class="login-box">
  @* <div class="login-logo">
    <a asp-controller="home" asp-action="index" ><img class="img-fluid" style="max-width: 200px;" src="/dist/img/logo.png"></a>
  </div> *@
  <!-- /.login-logo -->
  <div class="card">
    <div class="card-body login-card-body">
      <p class="login-box-msg">Oturum açmak için giriş yapın!..</p>

      <form asp-controller="login" asp-action="index" method="Post">
        <div class="input-group mb-3">
          <input asp-for="@Model.username" type="text" class="form-control" placeholder="Kullanıcı adı">
          <div class="input-group-append">
            <div class="input-group-text">
              <span class="fas fa-user"></span>
            </div>
          </div>
        </div>
        <div class="input-group mb-3">
          <input asp-for="@Model.password" type="password" class="form-control" placeholder="Şifre">
          <div class="input-group-append">
            <div class="input-group-text">
              <span class="fas fa-lock"></span>
            </div>
          </div>
        </div>
        <div class="row">
          <div class="col-8">
            <div class="icheck-primary">
              <input type="checkbox" id="remember">
              <label for="remember">
                Beni Hatırla
              </label>
            </div>
          </div>
          <!-- /.col -->
          <div class="col-4">
            <button type="submit" class="btn">Giriş</button>
          </div>
          <!-- /.col -->
        </div>
      </form>
    </div>
    <!-- /.login-card-body -->
  </div>
</div>