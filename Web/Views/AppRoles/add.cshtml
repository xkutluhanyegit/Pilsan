@model Entities.Concrete.AppRole
@{
    ViewData["Title"] = "Rol Ekle";
    Layout = "_Layout";
}

<div class="card card-primary">
    <div class="card-header">
        <h3 class="card-title">Rol Kayıt Ekranı</h3>
    </div>
    <!-- /.card-header -->
    <!-- form start -->
    <form asp-controller="approles" asp-action="add" method="post">
        <div class="card-body">
            <div class="form-group">
                <label for="exampleInputEmail1">Rol Adı</label>
                <input asp-for="@Model.RolName" type="text" class="form-control" id="exampleInputEmail1"
                    placeholder="Kullanıcı Adı">
            </div>

        </div>
        <!-- /.card-body -->

        <div class="card-footer">
            <button id="save-btn" type="submit" class="btn btn-primary float-right">Kaydet</button>
        </div>
    </form>
</div>
