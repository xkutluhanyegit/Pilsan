@model IEnumerable<Entities.DTOs.PersonelInfoDto>;
@{
  ViewData["Title"] = "İnsan Kaynakları";
}

<!-- Info boxes -->
<div class="row">
  <div class="col-12 col-sm-6 col-md-3">
    <div class="info-box">
      <span class="info-box-icon bg-info elevation-1"><i class="fa-solid fa-industry"></i></span>

      <div class="info-box-content">
        <span class="info-box-text">Toplam Çalışan Sayısı</span>
        <span class="info-box-number">
          @ViewBag.Data
          <small></small>
        </span>
      </div>
      <!-- /.info-box-content -->
    </div>
    <!-- /.info-box -->
  </div>
  <!-- /.col -->
  <div class="col-12 col-sm-6 col-md-3">
    <div class="info-box mb-3">
      <span class="info-box-icon bg-danger elevation-1"></span>

      <div class="info-box-content">
        <span class="info-box-text">Title2</span>
        <span class="info-box-number">00,00</span>
      </div>
      <!-- /.info-box-content -->
    </div>
    <!-- /.info-box -->
  </div>
  <!-- /.col -->

  <!-- fix for small devices only -->
  <div class="clearfix hidden-md-up"></div>

  <div class="col-12 col-sm-6 col-md-3">
    <div class="info-box mb-3">
      <span class="info-box-icon bg-success elevation-1"></span>

      <div class="info-box-content">
        <span class="info-box-text">Title3</span>
        <span class="info-box-number">00,00</span>
      </div>
      <!-- /.info-box-content -->
    </div>
    <!-- /.info-box -->
  </div>
  <!-- /.col -->
  <div class="col-12 col-sm-6 col-md-3">
    <div class="info-box mb-3">
      <span class="info-box-icon bg-warning elevation-1"></span>

      <div class="info-box-content">
        <span class="info-box-text">Title4</span>
        <span class="info-box-number">00,00</span>
      </div>
      <!-- /.info-box-content -->
    </div>
    <!-- /.info-box -->
  </div>
  <!-- /.col -->
</div>

<!-- /.row -->
<div class="card">
  <div class="card-header">
    <h3 class="card-title">Personel Listesi</h3>
  </div>
  <!-- /.card-header -->
  <div class="card-body">
    <table id="example1" class="table table-bordered table-striped">
      <thead>
        <tr>
          <th>#</th>
          <th>Sicil No</th>
          <th>Departman</th>
          <th>Personel Ad Soyad</th>
          <th>Bölge</th>
          <th>Durak</th>
          <th>Detay</th>
        </tr>
      </thead>
      <tbody>

        @{
          int count = 1;
          @foreach (var item in Model)
          {
            <tr>
              <td>@count</td>
              <td>@item.SicilNo</td>
              <td>@item.DepartmanName</td>
              <td>@item.Name @item.Surname</td>
              <td>@item.Shuttle</td>
              <td>@item.Station</td>
              <td>Detay</td>
            </tr>
            count++;
          }
        }

      </tbody>
      <tfoot>
        <tr>
          <th>#</th>
          <th>Sicil No</th>
          <th>Departman</th>
          <th>Personel Ad Soyad</th>
          <th>Bölge</th>
          <th>Durak</th>
          <th>Detay</th>
        </tr>
      </tfoot>
    </table>
  </div>
  <!-- /.card-body -->
</div>
